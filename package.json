{
  "name": "vsc-extension-grouper",
  "displayName": "VSCode Extension Grouper",
  "description": "Group, view, and manage your installed VSCode extensions with ease.",
  "version": "1.0.0",
  "publisher": "drem666",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension-grouper.open",
        "title": "Open Extension Grouper"
      }
    ]
  },
  "scripts": {
    "compile": "npx tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "extensions.disabled": [
  "publisher.extensionName",
  "other.extension.id"
]
}
