{
  "name": "vsc-extension-grouper",
  "displayName": "Extension Grouper",
  "description": "Group, activate, deactivate, and backup your VSCode extensions with an elegant interface.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extensionGrouper.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extensionGrouper.openPanel",
        "title": "Open Extension Grouper"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "postinstall": "npm install --save-dev @types/node @types/vscode"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/vscode": "^1.104.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  }
}
